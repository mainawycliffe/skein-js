# Point these at a running skein-js server (see docs/react-sdk.md).
# Copy to .env.local and adjust.

# skein-js server base URL (matches `skein dev` default port).
NEXT_PUBLIC_SKEIN_URL=http://localhost:2024

# A graph id from your langgraph.json (the gemini-chat example serves `gemini`).
NEXT_PUBLIC_SKEIN_ASSISTANT_ID=gemini
