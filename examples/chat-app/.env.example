# The research agent runs on Gemini. Get a Gemini Developer API key at
# https://aistudio.google.com/apikey, then copy this file to .env and fill it in.

GOOGLE_API_KEY=AIza...

# Optional — override the Gemini model (must support "thinking").
# GOOGLE_MODEL=gemini-2.5-flash

# Optional — enable real web search via Tavily (https://tavily.com). Without it, the web_search
# tool returns a deterministic placeholder so the demo still runs on the Gemini key alone.
# TAVILY_API_KEY=tvly-...
