{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "agent-protocol",
  "sourceRoot": "packages/agent-protocol/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsup src/index.ts --format esm --dts --clean",
        "cwd": "packages/agent-protocol"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/agent-protocol"
      }
    }
  }
}
